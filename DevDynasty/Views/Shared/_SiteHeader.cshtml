@{
    var currentPath = Context.Request.Path.Value?.ToLowerInvariant() ?? "/";
    bool isAdmin = currentPath.StartsWith("/admin");
}

<header class="header">

    <div class="container">

        <!-- Logo -->
        <a href="@(isAdmin ? "/Admin/Dashboard" : "/")" class="logo">
            <div class="logo-circle">
                @(isAdmin ? "ADMIN" : "FOVT")
            </div>
        </a>

        <!-- Navigation -->
        <nav>

            <ul class="nav-links">

                @if (isAdmin)
                {
                    <!-- ADMIN NAV -->

                    <li>
                        <a href="/Admin/Dashboard"
                           class="@(currentPath.Contains("/admin/dashboard") ? "nav-link-active" : "")">
                            Home
                        </a>
                    </li>

                    <li>
                        <a href="/Admin/Donations"
                           class="@(currentPath.Contains("/admin/donations") ? "nav-link-active" : "")">
                            Donations
                        </a>
                    </li>

                    <li>
                        <a href="/Admin/Donors"
                           class="@(currentPath.Contains("/admin/donors") ? "nav-link-active" : "")">
                            Donors
                        </a>
                    </li>

                    <li>
                        <a href="/Admin/Payments"
                           class="@(currentPath.Contains("/admin/payments") ? "nav-link-active" : "")">
                            Payments
                        </a>
                    </li>
                }
                else
                {
                    <!-- USER NAV -->

                    <li>
                        <a href="/" class="@(currentPath == "/" ? "nav-link-active" : "")">
                            Home
                        </a>
                    </li>

                    <li class="dropdown">

                        <a href="#">About</a>

                        <ul class="dropdown-menu">
                            <li><a href="/Home/About">About Us</a></li>
                            <li><a href="/Home/Services">Services</a></li>
                            <li><a href="/Home/Reports">Reports</a></li>
                            <li><a href="/Home/Contact">Contact</a></li>
                        </ul>

                    </li>

                    <li class="dropdown">

                        <a href="#">Get Involved</a>

                        <ul class="dropdown-menu">
                            <li><a href="/Home/Events">Events</a></li>
                            <li><a href="/Home/Volunteer">Volunteer</a></li>
                        </ul>

                    </li>

                    <li>
                        <a href="/Home/Community">
                            Community
                        </a>
                    </li>
                }

            </ul>

        </nav>

        <!-- CTA -->
        <div class="header-actions">

            @if (!isAdmin)
            {
                <a href="/Account/Login" class="btn-login">
                    Log In / Sign Up
                </a>

                <a href="/DonationUser/Index" class="btn-donate">
                    Donate
                </a>
            }

        </div>

    </div>

</header>