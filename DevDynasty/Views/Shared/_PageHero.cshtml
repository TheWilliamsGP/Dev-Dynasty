@{
    var title = ViewData["HeroTitle"]?.ToString() ?? "";
    var subtitle = ViewData["HeroSubtitle"]?.ToString();
}

<section class="bg-secondary-60">
    <div class="mx-auto max-w-7xl px-4 py-16 text-center">
        <h1 class="font-serif text-4xl font-bold text-foreground md:text-5xl">@title</h1>

        @if (!string.IsNullOrWhiteSpace(subtitle))
        {
        <p class="mx-auto mt-4 max-w-2xl text-base text-muted-foreground md:text-lg">
            @subtitle
        </p>
        }
    </div>
</section>