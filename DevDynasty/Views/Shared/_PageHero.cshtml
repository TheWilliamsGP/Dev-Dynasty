@{
    var title = ViewData["HeroTitle"]?.ToString() ?? "";
    var subtitle = ViewData["HeroSubtitle"]?.ToString();
}

<section class="hero">
    <div class="hero-content">
        <h1>@title</h1>

        @if (!string.IsNullOrWhiteSpace(subtitle))
        {
            <p>@subtitle</p>
        }

        <a href="/DonationUser/Index" class="btn-donate">Support Our Cause</a>
    </div>
</section>