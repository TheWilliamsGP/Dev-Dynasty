@model DevDynasty.Models.AdminEvents.AdminEventFormViewModel

@{
    ViewData["Title"] = "Create Event";
}

<section class="mx-auto max-w-4xl px-4 py-16">
    <a href="/admin/events" class="text-sm text-primary hover:opacity-80">← Back to events</a>

    <h1 class="mt-4 font-serif text-4xl font-bold">Create Event</h1>
    <p class="mt-2 text-muted-foreground">Add a new event and define how many volunteers are needed.</p>

    <form asp-action="Create" method="post" class="mt-8 rounded-xl border bg-card p-6 shadow-sm">
        @Html.AntiForgeryToken()

        <partial name="_EventForm" model="Model" />

        <div class="mt-8 flex gap-3">
            <button type="submit" class="rounded-md bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:opacity-90">
                Create Event
            </button>

            <a href="/admin/events" class="rounded-md border border-input px-6 py-3 text-sm font-semibold">
                Cancel
            </a>
        </div>
    </form>
</section>