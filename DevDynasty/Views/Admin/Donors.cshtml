@model List<DonorDto>

<section class="section-light min-h-screen py-10">

    <div class="max-w-7xl mx-auto px-6">

        <div class="mb-8">

            <h2 class="text-3xl font-bold">
                Donors
            </h2>

            <p class="text-gray-500 mt-2">
                Registered donor information and supporter details.
            </p>

        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            @foreach (var d in Model)
            {
                <div class="bg-white border border-gray-200 rounded-2xl shadow-2xl p-6">

                    <h3 class="text-xl font-semibold">
                        @d.donarname
                    </h3>

                    <p class="text-gray-500 mt-2">
                        @d.donaremail
                    </p>

                    <p class="mt-3 text-sm text-gray-700">
                        @d.field
                    </p>

                </div>
            }

        </div>

    </div>

</section>