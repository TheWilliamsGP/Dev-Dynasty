@model List<DonorDto>

<h2 class="text-2xl font-bold mb-6">Donors</h2>

<div class="grid grid-cols-3 gap-4">

    @foreach (var d in Model)
    {
        <div class="bg-gray-50 p-4 rounded-lg shadow-sm">
            <h3 class="font-semibold">@d.donarname</h3>
            <p class="text-sm text-gray-500">@d.donaremail</p>
            <p class="text-sm">@d.field</p>
        </div>
    }

</div>