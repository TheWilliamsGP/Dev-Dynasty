@model List<AdminDonationViewModel>

<section class="section-light min-h-screen py-10">

    <div class="max-w-7xl mx-auto px-6">

        <div class="mb-8">

            <h2 class="text-3xl font-bold">
                Donations
            </h2>

            <p class="text-gray-500 mt-2">
                View all monetary and non-monetary donations.
            </p>

        </div>

        <div class="bg-white border border-gray-200 rounded-2xl shadow-2xl p-8">

            <table class="w-full text-left">

                <thead class="border-b text-gray-500 text-sm">

                    <tr>
                        <th class="py-4">Donor</th>
                        <th>Amount</th>
                        <th>Content</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Anonymous</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var d in Model)
                    {
                        <tr class="border-b hover:bg-gray-50">

                            <td class="py-4 font-medium">
                                @(d.IsAnonymous ? "Anonymous" : d.DonorName)
                            </td>

                            <td>
                                @(d.IsMonetary ? $"R {d.Amount}" : "-")
                            </td>

                            <td>
                                @d.Content
                            </td>

                            <td>

                                <span class="px-3 py-1 rounded-full text-sm
                                        @(d.IsMonetary
                                                                              ? "bg-green-100 text-green-700"
                                                                              : "bg-blue-100 text-blue-700")">

                                    @(d.IsMonetary ? "Monetary" : "Goods")

                                </span>

                            </td>

                            <td>
                                @d.Date.ToShortDateString()
                            </td>

                            <td>

                                <span class="px-3 py-1 rounded-full text-sm
                                        @(d.IsAnonymous
                                                                              ? "bg-gray-200 text-gray-700"
                                                                              : "bg-green-100 text-green-700")">

                                @(d.IsAnonymous ? "Yes" : "No")

                                </span>

                            </td>

                        </tr>
                                        }

                </tbody>

            </table>

        </div>

    </div>

</section>