@model DevDynasty.Models.VolunteerDashboard.VolunteerDashboardViewModel

@{
    ViewData["Title"] = "Volunteer Dashboard";
}

<section class="mx-auto max-w-7xl px-4 py-16">
    <div class="rounded-xl border bg-card p-6 shadow-sm">
        <p class="text-sm text-muted-foreground">Welcome back</p>
        <h1 class="mt-2 font-serif text-4xl font-bold">@Model.VolunteerName</h1>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
            <a href="/volunteer/events/@Model.VolunteerId" class="dashboard-menu-card">
                <span class="dashboard-menu-title">Events</span>
                <span class="dashboard-menu-text">View event details and volunteer for upcoming events.</span>
            </a>

            <button type="button" class="dashboard-menu-card text-left">
                <span class="dashboard-menu-title">Donations</span>
                <span class="dashboard-menu-text">Donation section coming soon.</span>
            </button>

            <a href="/" class="dashboard-menu-card">
                <span class="dashboard-menu-title">Back to Website</span>
                <span class="dashboard-menu-text">Return to the public site.</span>
            </a>
        </div>
    </div>

    <div class="mt-10">
        <div class="flex items-center justify-between">
            <h2 class="font-serif text-3xl font-bold">Upcoming Events</h2>
            <a href="/volunteer/events/@Model.VolunteerId" class="text-sm font-semibold text-primary">View all</a>
        </div>

        <div class="mt-6 grid gap-6 md:grid-cols-2">
            @foreach (var item in Model.Events.Take(4))
            {
                <div class="rounded-xl border bg-card p-6 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(item.EventImageUrl))
                    {
                        <img src="@item.EventImageUrl" alt="@item.EventName" class="volunteer-event-image" />
                    }

                    <p class="text-sm font-semibold text-primary">@item.EventType</p>
                    <h3 class="mt-2 font-serif text-2xl font-bold">@item.EventName</h3>

                    <p class="mt-3 text-muted-foreground">
                        @item.EventDescription
                    </p>

                    <div class="mt-4 text-sm text-muted-foreground">
                        <p><strong>Date:</strong> @item.EventStartDate</p>
                        <p><strong>Location:</strong> @item.LocationAddress</p>
                        <p><strong>Volunteers:</strong> @item.JoinedVolunteers / @item.RequiredVolunteers</p>
                        <p><strong>Status:</strong> @item.StaffingStatus</p>
                    </div>

                    <div class="mt-6 flex flex-wrap gap-3">
                        <a href="/volunteer/events/details/@Model.VolunteerId/@item.EventId" class="rounded-md border border-input px-4 py-2 text-sm font-semibold">
                            View Details
                        </a>

                        @if (item.HasJoined)
                        {
                            <span class="rounded-md bg-muted px-4 py-2 text-sm font-semibold text-muted-foreground">
                                Already Volunteered
                            </span>
                        }
                        else if (item.CanVolunteer)
                        {
                            <form asp-action="JoinEvent" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="volunteerId" value="@Model.VolunteerId" />
                                <input type="hidden" name="eventId" value="@item.EventId" />

                                <button type="submit" class="rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground">
                                    Volunteer
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>