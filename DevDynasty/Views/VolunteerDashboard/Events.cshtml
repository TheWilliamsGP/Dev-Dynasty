@model DevDynasty.Models.VolunteerDashboard.VolunteerDashboardViewModel

@{
    ViewData["Title"] = "Volunteer Events";
}

<section class="mx-auto max-w-7xl px-4 py-16">
    <a href="/volunteer/dashboard/@Model.VolunteerId" class="text-sm text-primary hover:opacity-80">← Back to dashboard</a>

    <div class="mt-4">
        <h1 class="font-serif text-4xl font-bold">Events</h1>
        <p class="mt-2 text-muted-foreground">
            View event details and volunteer for events you would like to support.
        </p>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
        @if (!Model.Events.Any())
        {
            <div class="rounded-xl border bg-card p-6 shadow-sm">
                <p class="text-muted-foreground">No events are currently available.</p>
            </div>
        }
        else
        {
            foreach (var item in Model.Events)
            {
                <div class="rounded-xl border bg-card p-6 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(item.EventImageUrl))
                    {
                        <img src="@item.EventImageUrl" alt="@item.EventName" class="volunteer-event-image" />
                    }

                    <p class="text-sm font-semibold text-primary">@item.EventType</p>
                    <h2 class="mt-2 font-serif text-2xl font-bold">@item.EventName</h2>

                    <p class="mt-3 text-muted-foreground">
                        @item.EventDescription
                    </p>

                    <div class="mt-4 text-sm text-muted-foreground">
                        <p><strong>Start date:</strong> @item.EventStartDate</p>

                        @if (!string.IsNullOrWhiteSpace(item.EventEndDate))
                        {
                            <p><strong>End date:</strong> @item.EventEndDate</p>
                        }

                        <p><strong>Location:</strong> @item.LocationAddress</p>
                        <p><strong>Volunteers:</strong> @item.JoinedVolunteers / @item.RequiredVolunteers</p>
                        <p><strong>Status:</strong> @item.StaffingStatus</p>
                    </div>

                    <div class="mt-6 flex flex-wrap gap-3">
                        <a href="/volunteer/events/details/@Model.VolunteerId/@item.EventId" class="rounded-md border border-input px-4 py-2 text-sm font-semibold">
                            View Details
                        </a>

                        @if (item.HasJoined)
                        {
                            <span class="rounded-md bg-muted px-4 py-2 text-sm font-semibold text-muted-foreground">
                                Already Volunteered
                            </span>

                            <form asp-action="UnvolunteerEvent" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="volunteerId" value="@Model.VolunteerId" />
                                <input type="hidden" name="eventId" value="@item.EventId" />

                                <button type="submit" class="rounded-md border border-input px-4 py-2 text-sm font-semibold text-destructive">
                                    Unvolunteer
                                </button>
                            </form>
                        }
                        else if (item.CanVolunteer)
                        {
                            <form asp-action="JoinEvent" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="volunteerId" value="@Model.VolunteerId" />
                                <input type="hidden" name="eventId" value="@item.EventId" />

                                <button type="submit" class="rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground">
                                    Volunteer
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
    </div>
</section>