@model DevDynasty.Models.VolunteerDashboard.VolunteerEventDetailsViewModel

@{
    ViewData["Title"] = "Event Details";
}

<section class="mx-auto max-w-5xl px-4 py-16">
    <a href="/volunteer/events/@Model.VolunteerId" class="text-sm text-primary hover:opacity-80">← Back to events</a>

    <div class="mt-6 rounded-xl border bg-card p-6 shadow-sm">
        <p class="text-sm font-semibold text-primary">@Model.Event.EventType</p>
        <h1 class="mt-2 font-serif text-4xl font-bold">@Model.Event.EventName</h1>

        <p class="mt-4 text-muted-foreground">
            @Model.Event.EventDescription
        </p>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
            <div>
                <h2 class="font-serif text-xl font-semibold">Event Information</h2>

                <p class="mt-3"><strong>Start date:</strong> @Model.Event.EventStartDate</p>
                <p class="mt-2"><strong>End date:</strong> @Model.Event.EventEndDate</p>
                <p class="mt-2"><strong>Location:</strong> @Model.Event.LocationAddress</p>
            </div>

            <div>
                <h2 class="font-serif text-xl font-semibold">Volunteer Status</h2>

                <p class="mt-3"><strong>Volunteers joined:</strong> @Model.Event.JoinedVolunteers / @Model.Event.RequiredVolunteers</p>
                <p class="mt-2"><strong>Status:</strong> @Model.Event.StaffingStatus</p>

                <div class="mt-6">
                    @if (Model.Event.HasJoined)
                    {
                        <span class="rounded-md bg-muted px-4 py-2 text-sm font-semibold text-muted-foreground">
                            You have already volunteered for this event.
                        </span>
                    }
                    else if (Model.Event.CanVolunteer)
                    {
                        <form asp-action="JoinEvent" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="volunteerId" value="@Model.VolunteerId" />
                            <input type="hidden" name="eventId" value="@Model.Event.EventId" />

                            <button type="submit" class="rounded-md bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground">
                                Volunteer for this Event
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="rounded-md bg-muted px-4 py-2 text-sm font-semibold text-muted-foreground">
                            This event is no longer open for volunteers.
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
</section>