@model DevDynasty.Models.UserDonationViewModel

<div class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="bg-white shadow-lg rounded-xl p-8 w-full max-w-md">

        <h2 class="text-2xl font-bold text-center mb-6">Make a Donation</h2>

        <form asp-action="Index" method="post" class="space-y-4">

            <div>
                <label asp-for="DonationAmount" class="block text-sm font-medium mb-1"></label>
                <input asp-for="DonationAmount" type="number"
                       class="w-full border rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                       placeholder="Enter amount"
                       required />
                <span asp-validation-for="DonationAmount" class="text-red-500 text-sm"></span>
            </div>

            <div class="flex items-center">
                <input asp-for="IsAnonymous" type="checkbox" class="mr-2" />
                <label class="text-sm">Donate anonymously</label>
            </div>

            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700 transition">
                Next
            </button>

        </form>
    </div>
</div>