@model DevDynasty.Models.UserDonationViewModel

<h2>Make a Donation</h2>

<form asp-action="Index" method="post">

    <div>
        <label asp-for="DonationAmount"></label>
        <input asp-for="DonationAmount" type="number" required />
        <span asp-validation-for="DonationAmount"></span>
    </div>

    <div>
        <label>
            <input asp-for="IsAnonymous" type="checkbox" />
            Donate anonymously
        </label>
    </div>

    <button type="submit">Next</button>
</form>