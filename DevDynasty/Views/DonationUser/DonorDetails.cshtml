@model DevDynasty.Models.UserDonorViewModel

<section class="section-light min-h-screen flex items-center">

    <div class="content-container">

        <div class="bg-white rounded-xl shadow-lg p-10 max-w-xl mx-auto">

            <div class="text-center mb-8">

                <h2 class="text-3xl font-bold">Your Details</h2>

                <p class="mt-3 text-gray-600">
                    Please provide your details so we can process your donation
                    and keep accurate records of community support.
                </p>

            </div>

            <form asp-action="DonorDetails" method="post" class="space-y-6">

                <!-- Full Name -->
                <div>

                    <label asp-for="DonorName"
                           class="block text-sm font-semibold mb-2">
                        Full Name
                    </label>

                    <input asp-for="DonorName"
                           placeholder="Enter your full name"
                           class="w-full border border-gray-300 rounded-lg px-4 py-3
                                  focus:outline-none focus:ring-2 focus:ring-green-600"
                           required />

                    <span asp-validation-for="DonorName"
                          class="text-red-500 text-sm"></span>

                </div>

                <!-- Email -->
                <div>

                    <label asp-for="DonorEmail"
                           class="block text-sm font-semibold mb-2">
                        Email Address
                    </label>

                    <input asp-for="DonorEmail"
                           type="email"
                           placeholder="Enter your email address"
                           class="w-full border border-gray-300 rounded-lg px-4 py-3
                                  focus:outline-none focus:ring-2 focus:ring-green-600"
                           required />

                    <span asp-validation-for="DonorEmail"
                          class="text-red-500 text-sm"></span>

                </div>

                <!-- Country -->
                <div>

                    <label asp-for="Field"
                           class="block text-sm font-semibold mb-2">
                        Country
                    </label>

                    <input asp-for="Field"
                           placeholder="Enter your country"
                           class="w-full border border-gray-300 rounded-lg px-4 py-3
                                  focus:outline-none focus:ring-2 focus:ring-green-600"
                           required />

                    <span asp-validation-for="Field"
                          class="text-red-500 text-sm"></span>

                </div>

                <!-- Submit -->
                <button type="submit"
                        class="btn-donate w-full text-center">

                    @(ViewBag.IsMonetary ? "Continue to Payment" : "Donate")

                </button>

            </form>

        </div>

    </div>

</section>