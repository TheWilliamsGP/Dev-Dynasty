@{
    ViewData["HeroTitle"] = "Events & Community Involvement";
    ViewData["HeroSubtitle"] = "Join us in making a difference through meaningful community engagement.";
}

<partial name="_PageHero" />

<!-- INTRO -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Our Events</h2>

        <p class="mt-4">
            Our events bring together the community to support mental health initiatives,
            raise awareness, and create meaningful connections.
        </p>
    </div>
</section>

<!-- FUNDRAISING -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Fundraising Initiatives</h2>

        <p class="mt-4">
            Through fundraising events, we generate essential resources that directly
            support patient care and hospital programmes.
        </p>
    </div>
</section>

<!-- OUTREACH -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Community Outreach</h2>

        <p class="mt-4">
            Our outreach programmes engage the public, promote awareness,
            and help reduce stigma surrounding mental health.
        </p>
    </div>
</section>

<!-- VOLUNTEERS -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Volunteer-Led Events</h2>

        <p class="mt-4">
            Volunteers play a vital role in organising and running our events,
            helping create meaningful and welcoming experiences.
        </p>
    </div>
</section>

<!-- IMPACT -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Our Impact</h2>

        <p class="mt-4">
            Our work continues to grow through community involvement and support.
        </p>

        <div class="flex justify-between mt-6">
            <div>
                <h3 class="text-3xl">300+</h3>
                <p>Patients Supported</p>
            </div>

            <div>
                <h3 class="text-3xl">50+</h3>
                <p>Volunteers</p>
            </div>

            <div>
                <h3 class="text-3xl">20+</h3>
                <p>Events Hosted</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Get Involved</h2>

        <p class="mt-4">
            Whether attending an event or volunteering, your contribution helps
            us continue supporting mental health care.
        </p>

        <a href="/Home/Volunteer" class="btn-donate mt-6">Become a Volunteer</a>
    </div>
</section>