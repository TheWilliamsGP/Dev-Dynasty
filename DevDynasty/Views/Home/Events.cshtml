@{
    ViewData["Title"] = "Events";
}

<section class="hero">
    <h1>Events & Community Involvement</h1>
    <p>Join us in making a difference through meaningful community engagement.</p>
</section>

<section class="section-light">
    <div class="content-container">

        <h2>Our Events</h2>
        <p>
            Friends of Valkenberg Trust hosts a variety of events aimed at supporting mental health
            initiatives, raising awareness, and bringing the community together. These events play a
            vital role in improving the lives of patients and strengthening support networks.
        </p>

        <div class="section-divider"></div>

        <div class="card">
            <h3>Fundraising Initiatives</h3>
            <p>
                Our fundraising events are designed to generate critical resources that directly support
                patient care and hospital programs. From charity drives to sponsored events, each initiative
                contributes to meaningful change.
            </p>
        </div>

        <div class="card mt-6">
            <h3>Community Outreach</h3>
            <p>
                We actively engage with the wider community through outreach programs that promote mental
                health awareness, reduce stigma, and encourage public participation in support initiatives.
            </p>
        </div>

        <div class="card mt-6">
            <h3>Volunteer-Led Events</h3>
            <p>
                Our volunteers play a key role in organizing and running events. Their dedication helps
                create welcoming, impactful experiences for both patients and the community.
            </p>
        </div>

    </div>
</section>

<section class="section-light">
    <div class="content-container text-center">

        <h2>Our Impact</h2>

        <div class="flex justify-between mt-6">

            <div>
                <h3 class="text-3xl">300+</h3>
                <p>Patients Supported</p>
            </div>

            <div>
                <h3 class="text-3xl">50+</h3>
                <p>Volunteers</p>
            </div>

            <div>
                <h3 class="text-3xl">20+</h3>
                <p>Events Hosted</p>
            </div>

        </div>

    </div>
</section>

<section class="section-alt">
    <div class="content-container text-center">

        <h2>Get Involved</h2>
        <p>
            Whether attending an event or volunteering your time, your contribution helps us continue
            our mission of supporting mental health care.
        </p>

        <a href="/Home/Volunteer" class="btn-donate mt-4">Become a Volunteer</a>

    </div>
</section>