@{
    ViewData["HeroTitle"] = "About Us";
    ViewData["HeroSubtitle"] = "Supporting mental health recovery through compassion, community, and care.";
}

<partial name="_PageHero" />

<!-- WHO WE ARE -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Who We Are</h2>

        <p class="mt-4">
            Friends of Valkenberg Trust is a non-profit organisation dedicated to supporting
            patients at Valkenberg Hospital. Our work focuses on enhancing recovery by providing
            resources, programmes, and community-driven support.
        </p>

        <p class="mt-4">
            We work alongside healthcare professionals, volunteers, and donors to create an
            environment where individuals are treated with dignity, compassion, and respect.
        </p>
    </div>
</section>

<!-- WHAT WE DO -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>What We Do</h2>

        <p class="mt-4">
            Our initiatives bridge the gap between clinical care and human connection.
            We provide practical support, facilitate engagement, and create opportunities
            for patients to rebuild confidence and independence.
        </p>

        <p class="mt-4">
            Through fundraising, outreach, and volunteer-driven programmes, we ensure
            continued support for those in need.
        </p>
    </div>
</section>

<!-- HISTORY -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Our History</h2>

        <p class="mt-4">
            The Trust began as a small initiative focused on improving patient wellbeing
            at Valkenberg Hospital. Over time, it has grown into a structured organisation
            supported by a network of dedicated volunteers and partners.
        </p>

        <p class="mt-4">
            Our continued growth reflects a strong commitment to community involvement
            and sustainable mental health support.
        </p>
    </div>
</section>

<!-- GOVERNANCE + NETWORKING -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Governance & Partnerships</h2>

        <p class="mt-4">
            The Trust is guided by a committed governance structure that ensures
            transparency, accountability, and responsible use of resources.
        </p>

        <p class="mt-4">
            We collaborate with healthcare professionals, community organisations,
            and supporters to expand our reach and maximise our impact.
        </p>
    </div>
</section>

<!-- REPORTS -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Reports & Transparency</h2>

        <p class="mt-4">
            We prioritise transparency and accountability in everything we do.
            Our reports provide insight into our activities, finances, and impact.
        </p>

        <ul class="mt-6">
            <li><a href="#">Annual Report 2024</a></li>
            <li><a href="#">Event Reports</a></li>
        </ul>
    </div>
</section>

<!-- CTA -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Get in Touch</h2>

        <p class="mt-4">
            Whether you want to support our work, partner with us, or learn more,
            we would love to hear from you.
        </p>

        <p class="mt-4">Email: info@fovt.org</p>

        <a href="/Home/Contact" class="btn-donate mt-6">Contact Us</a>
    </div>
</section>