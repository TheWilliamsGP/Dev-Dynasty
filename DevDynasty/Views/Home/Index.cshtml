@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="hero">
    <h1>Supporting Mental Health Recovery</h1>
    <p>
        Friends of Valkenberg Trust works to restore dignity, build community,
        and support recovery for individuals living with serious mental illness.
    </p>

    <div class="mt-6">
        <a href="/Home/About" class="btn-donate">Learn More</a>
    </div>
</section>

<!-- ABOUT PREVIEW -->
<section class="section-light">
    <div class="content-container text-center">

        <h2>Who We Are</h2>

        <p class="mt-4">
            We are a non-profit organisation dedicated to supporting patients at Valkenberg Hospital.
            Through compassion, collaboration, and community-driven initiatives, we help bridge the gap
            between clinical care and human connection.
        </p>

        <a href="/Home/About" class="btn-donate mt-6">About Us</a>

    </div>
</section>

<!-- SERVICES PREVIEW -->
<section class="section-alt">
    <div class="content-container text-center">

        <h2>What We Do</h2>

        <p class="mt-4">
            Our services focus on recovery, dignity, and support. From providing basic needs
            to facilitating recovery groups and recreational activities, we create opportunities
            for healing and growth.
        </p>

        <p class="mt-4">
            Every programme is designed to empower individuals and improve quality of life
            during their recovery journey.
        </p>

        <a href="/Home/Services" class="btn-donate mt-6">Explore Services</a>

    </div>
</section>

<!-- IMPACT / REPORTS -->
<section class="section-light">
    <div class="content-container text-center">

        <h2>Our Impact</h2>

        <p class="mt-4">
            Transparency and accountability are at the heart of our work. Our annual reports
            showcase the real impact of our initiatives and the difference made through
            community support.
        </p>

        <div class="flex justify-center gap-10 mt-6">

            <div>
                <h3 class="text-3xl">300+</h3>
                <p>Patients Supported</p>
            </div>

            <div>
                <h3 class="text-3xl">60+</h3>
                <p>Volunteers</p>
            </div>

            <div>
                <h3 class="text-3xl">20+</h3>
                <p>Programs Running</p>
            </div>

        </div>

        <a href="/Home/Reports" class="btn-donate mt-6">View Reports</a>

    </div>
</section>

<!-- VOLUNTEER -->
<section class="section-alt">
    <div class="content-container text-center">

        <h2>Get Involved</h2>

        <p class="mt-4">
            Volunteers are the heart of our organisation. By giving your time and energy,
            you become part of a compassionate community working to uplift others.
        </p>

        <p class="mt-4">
            Whether through events, outreach, or direct support, your contribution matters.
        </p>

        <a href="/Home/Volunteer" class="btn-donate mt-6">Become a Volunteer</a>

    </div>
</section>

<!-- DONATION -->
<section class="section-light">
    <div class="content-container text-center">

        <h2>Support Our Work</h2>

        <p class="mt-4">
            Your support allows us to continue providing essential resources and programmes
            for patients in need. Every contribution helps restore dignity and hope.
        </p>

        <p class="mt-4">
            Together, we can make a meaningful and lasting difference.
        </p>

        <a href="/Home/Donate" class="btn-donate mt-6">Donate Now</a>

    </div>
</section>

<!-- FINAL CTA -->
<section class="section-alt">
    <div class="content-container text-center">

        <h2>Be Part of the Change</h2>

        <p class="mt-4">
            Join us in building a community that supports recovery, dignity, and compassion.
        </p>

        <a href="/Home/Contact" class="btn-donate mt-6">Get in Touch</a>

    </div>
</section>