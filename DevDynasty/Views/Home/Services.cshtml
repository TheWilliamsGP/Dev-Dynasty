@{
    ViewData["HeroTitle"] = "Our Services";
    ViewData["HeroSubtitle"] = "Through 60+ volunteers, we work with hospital staff to bring hope, comfort and dignity to patients.";
}

<partial name="_PageHero" />

<section class="mx-auto grid max-w-6xl gap-6 px-4 py-16 md:grid-cols-2">
    <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h3 class="font-serif text-xl font-semibold">Patient Support</h3>
        <p class="mt-2 text-muted-foreground">
            One-on-one time with patients — listening, conversation, and companionship.
        </p>
    </div>

    <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h3 class="font-serif text-xl font-semibold">Recreational Activities</h3>
        <p class="mt-2 text-muted-foreground">
            Music, art, gardening and outings to support wellbeing and recovery.
        </p>
    </div>

    <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h3 class="font-serif text-xl font-semibold">Practical Assistance</h3>
        <p class="mt-2 text-muted-foreground">
            Toiletries, clothing and small comforts for patients in need.
        </p>
    </div>

    <div class="rounded-xl border bg-card p-6 shadow-sm">
        <h3 class="font-serif text-xl font-semibold">Reintegration Help</h3>
        <p class="mt-2 text-muted-foreground">
            Supporting patients as they prepare to return to their communities.
        </p>
    </div>
</section>