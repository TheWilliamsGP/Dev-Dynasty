@{
    ViewData["HeroTitle"] = "Our Services";
    ViewData["HeroSubtitle"] = "Through awareness, support, and community engagement, we help improve the lives of patients at Valkenberg Hospital.";
}

<partial name="_PageHero" />

<!-- AWARENESS -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Raising Awareness</h2>

        <p class="mt-4">
            We work to raise awareness around mental health and reduce stigma through education,
            outreach, and community engagement. By encouraging open conversations and understanding,
            we help create a more supportive environment for individuals living with mental illness.
        </p>
    </div>
</section>

<!-- OVERVIEW -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Overview of Our Work</h2>

        <p class="mt-4">
            Our services are designed to complement the care provided at Valkenberg Hospital.
            We focus on improving quality of life, supporting recovery, and building connections
            between patients and the broader community.
        </p>

        <p class="mt-4">
            Through a network of volunteers and supporters, we provide both practical assistance
            and emotional support to those who need it most.
        </p>
    </div>
</section>

<!-- RECOVERY GROUPS -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Recovery Groups</h2>

        <p class="mt-4">
            Our recovery groups provide a safe and supportive environment where patients can
            connect, share experiences, and build confidence. These sessions promote healing,
            self-expression, and a sense of belonging.
        </p>
    </div>
</section>

<!-- BASIC PATIENT NEEDS -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Basic Patient Needs</h2>

        <p class="mt-4">
            We assist in providing essential items such as clothing, toiletries, and other daily
            necessities to patients who may not have access to these resources.
        </p>

        <p class="mt-4">
            Meeting these basic needs is a crucial part of restoring dignity and ensuring that
            patients feel cared for and supported during their recovery journey.
        </p>
    </div>
</section>

<!-- RECREATIONAL RECOVERY -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Recreational Recovery</h2>

        <p class="mt-4">
            Recreational activities play an important role in recovery by promoting creativity,
            relaxation, and social interaction. We organise activities that allow patients to
            engage in meaningful and enjoyable experiences.
        </p>
    </div>
</section>

<!-- HOSPITAL SUPPORT -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>Hospital Staff Support</h2>

        <p class="mt-4">
            We work alongside hospital staff to provide additional support and resources that
            enhance patient care. By strengthening this collaboration, we help ensure a more
            holistic approach to treatment and recovery.
        </p>
    </div>
</section>

<!-- SKILLS DEVELOPMENT -->
<section class="section-light">
    <div class="content-container text-center">
        <h2>Skills Development</h2>

        <p class="mt-4">
            Skills development programmes help patients build confidence, independence, and
            practical abilities. These initiatives prepare individuals for reintegration into
            society and support long-term recovery.
        </p>
    </div>
</section>

<!-- FRIENDLY SHOP -->
<section class="section-alt">
    <div class="content-container text-center">
        <h2>The Friendly Shop</h2>

        <p class="mt-4">
            The Friendly Shop provides patients with access to affordable items in a supportive
            and welcoming environment. It also offers opportunities for patients to engage in
            meaningful activity and develop practical skills.
        </p>
    </div>
</section>

<!-- FINAL CTA -->
<section class="section-light">
    <div class="content-container text-center">

        <h2>Support Our Work</h2>

        <p class="mt-4">
            Our services are made possible through the support of volunteers, donors, and the
            wider community. Together, we can continue making a meaningful difference.
        </p>

        <a href="/Home/Donate" class="btn-donate mt-6">Get Involved</a>

    </div>
</section>