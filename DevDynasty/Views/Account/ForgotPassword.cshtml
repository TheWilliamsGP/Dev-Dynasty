@model DevDynasty.Models.VolunteerAuth.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<section class="mx-auto max-w-xl px-4 py-16">
    <a href="/account/login" class="text-sm text-primary hover:opacity-80">← Back to login</a>

    <div class="mt-6 rounded-xl border bg-card p-6 shadow-sm">
        <h1 class="font-serif text-4xl font-bold">Forgot Password</h1>

        <p class="mt-2 text-muted-foreground">
            Enter your email address and we will send you a link to reset your password.
        </p>

        <div asp-validation-summary="ModelOnly" class="form-error mt-4"></div>

        <form asp-action="ForgotPassword" method="post" class="mt-8 space-y-4" novalidate>
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-input" autocomplete="email" />
                <span asp-validation-for="Email" class="form-error"></span>
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
                <button type="submit" class="rounded-md bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground hover:opacity-90">
                    Send Reset Link
                </button>

                <a href="/account/login" class="rounded-md border border-input px-6 py-3 text-sm font-semibold">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>